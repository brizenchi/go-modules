# Copy to .env.local for local dev:
#   cp .env.example .env.local

# Public app origin. Must match the URL users open in the browser.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API origin + prefix mounted by the Go quickstart template.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# UI labels / defaults
NEXT_PUBLIC_APP_NAME=Clawmesh Quickstart Frontend
NEXT_PUBLIC_DEFAULT_PLAN=pro
NEXT_PUBLIC_DEFAULT_INTERVAL=monthly
NEXT_PUBLIC_DEFAULT_CREDITS_QUANTITY=1

# Optional. Leave blank if your backend already has one default credits price.
NEXT_PUBLIC_CREDITS_PRICE_ID=

# Frontend pages Stripe should send the browser back to after Checkout.
NEXT_PUBLIC_STRIPE_SUCCESS_PATH=/billing?checkout=success
NEXT_PUBLIC_STRIPE_CANCEL_PATH=/billing?checkout=cancelled
