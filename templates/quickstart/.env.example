# foundation/config reads process env. The quickstart template also
# auto-loads a local .env file at boot for easier local development.

# Optional: point quickstart at a different config file.
CONFIG=deploy/config.yaml

# Server / log
APP_SERVER_NAME=quickstart
APP_SERVER_PORT=8080
APP_LOG_LEVEL=info
APP_LOG_FORMAT=text

# Tracing (OTLP). Leave endpoint empty to disable span export while
# keeping tracing middleware mounted.
APP_TRACING_ENDPOINT=
APP_TRACING_PROTOCOL=http
APP_TRACING_INSECURE=true
APP_TRACING_SAMPLE_RATE=1

# Database
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_USER=app
APP_DB_PASSWORD=app
APP_DB_NAME=quickstart
APP_DB_SSL_MODE=disable
APP_DB_TIME_ZONE=UTC
# Optional legacy escape hatch:
# APP_DB_DSN=host=localhost user=app password=app dbname=quickstart port=5432 sslmode=disable TimeZone=UTC

# Auth
APP_AUTH_USER_JWT_SECRET=CHANGE-ME-32-RANDOM-CHARS
APP_AUTH_USER_JWT_EXPIRE_HOURS=168
APP_AUTH_WS_TICKET_TTL_SECONDS=300
APP_AUTH_FRONTEND_REDIRECT=http://localhost:3000/login

# Email-code login
APP_AUTH_EMAIL_DEBUG=true
APP_AUTH_EMAIL_VERIFICATION_TEMPLATE_REF=3
APP_AUTH_EMAIL_CODE_TTL_MINUTES=10
APP_AUTH_EMAIL_CODE_MIN_RESEND_GAP_SECONDS=60
APP_AUTH_EMAIL_CODE_DAILY_CAP=10
APP_AUTH_EMAIL_CODE_MAX_ATTEMPTS=5

# Email provider
APP_EMAIL_PROVIDER=log
APP_EMAIL_BREVO_API_KEY=
APP_EMAIL_BREVO_SENDER_EMAIL=
APP_EMAIL_BREVO_SENDER_NAME=quickstart

# Google OAuth
APP_AUTH_GOOGLE_CLIENT_ID=
APP_AUTH_GOOGLE_CLIENT_SECRET=
# Leaving client_id and client_secret empty keeps Google OAuth disabled,
# even if redirect_url and state_secret keep their local template values.
APP_AUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback
APP_AUTH_GOOGLE_STATE_SECRET=ANOTHER-CHANGE-ME-32-CHARS
APP_AUTH_GOOGLE_SCOPE=openid email profile

# Billing / Stripe
APP_BILLING_STRIPE_ENABLED=false
APP_BILLING_STRIPE_SECRET_KEY=
APP_BILLING_STRIPE_PUBLISHABLE_KEY=
APP_BILLING_STRIPE_WEBHOOK_SECRET=
APP_BILLING_STRIPE_TRIAL_DAYS=0
APP_BILLING_STRIPE_PRICES_STARTER_MONTHLY=
APP_BILLING_STRIPE_PRICES_STARTER_YEARLY=
APP_BILLING_STRIPE_PRICES_PRO_MONTHLY=
APP_BILLING_STRIPE_PRICES_PRO_YEARLY=
APP_BILLING_STRIPE_PRICES_CREDITS=
APP_BILLING_STRIPE_CREDITS_PER_PACKAGE=100

# Referral
APP_REFERRAL_PREFIX=INV
APP_REFERRAL_BASE_LINK=http://localhost:3000/invite?ref=
APP_REFERRAL_ACTIVATION_REWARD=50
