project: quickstart
env: dev

server:
  name: quickstart        # appears as "service" field in every log record
  port: 8080

log:
  level: info             # debug | info | warn | error
  format: json            # json | text — text is human-readable for dev

tracing:
  endpoint: ""            # e.g. localhost:4318 ; empty disables exporter
  protocol: http          # http | grpc
  insecure: true          # true for local collectors without TLS
  sample_rate: 1.0        # 0..1
  authorization: ""       # e.g. Basic <base64> for OpenObserve
  headers: {}             # e.g. { Authorization: "Basic <base64>" } for OpenObserve
  url_path: ""            # e.g. /api/default/v1/traces for OpenObserve

db:
  host: localhost
  port: 5432
  user: app
  password: app
  name: quickstart
  ssl_mode: disable
  time_zone: UTC
  log_level: warn
  slow_query_ms: 200
  # Optional legacy escape hatch if you still prefer a single connection string:
  # dsn: "host=localhost user=app password=app dbname=quickstart port=5432 sslmode=disable TimeZone=UTC"

# ---------- auth ----------
auth:
  user_jwt_secret: "CHANGE-ME-32-RANDOM-CHARS"
  user_jwt_expire_hours: 168       # 7 days
  ws_ticket_ttl_seconds: 300       # 5 minutes
  admin_emails: []                 # users with these emails get role=admin
  frontend_redirect: "http://localhost:3000/login"  # browser landing after backend Google callback

  email:
    debug: false                   # if true, send-code response leaks the code (dev only)
    code:
      ttl_minutes: 10
      min_resend_gap_seconds: 60
      daily_cap: 10
      max_attempts: 5
  google:
    client_id: ""                  # leave empty → Google login disabled
    client_secret: ""
    redirect_url: "http://localhost:8080/api/v1/auth/google/callback"
    state_secret: "ANOTHER-CHANGE-ME-32-CHARS"
    scope: "openid email profile"

# ---------- email ----------
email:
  provider: log                    # log | brevo | resend
  brevo:
    api_key: ""                    # required when provider=brevo
    sender_email: ""
    sender_name: "quickstart"
  resend:
    api_key: ""                    # required when provider=resend
    sender_email: ""
    sender_name: "quickstart"

# ---------- billing ----------
billing:
  stripe:
    secret_key: ""
    publishable_key: ""
    webhook_secret: ""
    trial_days: 0
    prices:
      starter_monthly: ""
      starter_yearly: ""
      pro_monthly: ""
      pro_yearly: ""
      premium_monthly: ""
      premium_yearly: ""
      lifetime: ""
      credits: []                  # list of one-time credit price IDs
    credits:
      per_package: 100             # credits granted per credits-package unit
    topup:
      min_amount_usd: 5            # minimum custom recharge amount in USD
      max_amount_usd: 10000        # maximum custom recharge amount in USD
      credits_per_usd: 100         # credits granted per 1 USD in custom recharge flow

# ---------- referral ----------
referral:
  prefix: "INV"                    # invitation code prefix
  base_link: "http://localhost:3000/invite?ref="
  activation_reward: 50            # credits granted to referrer on referee subscription
